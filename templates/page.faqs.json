          "type": "collapsible_row",
          "settings": {
            "heading": "HOW CAN I BECOME A CAPITTEN DISTRIBUTOR? ",
            "icon": "check_mark",
            "row_content": "<p>Interested in joining our distributor network? Write to us at hello@capitten.com to learn more about how to become part of our growing community of partners.</p>",
            "page": ""
          }
        },
        "collapsible_row_K9DDEm": {
